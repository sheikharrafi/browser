{
  "name": "feature-rich-browser",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome-অনুরূপ ব্রাউজার + 1DM Plus-অনুরূপ ডাউনলোড ম্যানেজার (Electron + TypeScript + React)",
  "main": "dist/main/index.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "node build/build.mjs",
    "watch": "node build/build.mjs --watch",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "dist": "npm run build && electron-builder"
  },
  "keywords": [
    "browser",
    "download-manager",
    "electron",
    "vpn"
  ],
  "license": "MIT",
  "author": {
    "name": "Feature Rich Browser",
    "email": "dev@example.com"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.23.0",
    "fast-check": "^3.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "build": {
    "publish": null,
    "appId": "com.example.feature-rich-browser",
    "productName": "FeatureRichBrowser",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": "AppImage",
      "category": "Network"
    }
  }
}
